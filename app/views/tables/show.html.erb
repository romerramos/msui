<div class="pt-16 lg:pt-0">
  <div class="overflow-x-auto bg-base-100 w-full">
    <div
      class="
        grid gap-px bg-base-200 border-y border-white/20 divide-x divide-white/20
      "
      style="grid-template-columns: repeat(<%= @table.fields.length %>, minmax(0, 1fr));"
    >
      <% @table.fields.each do |field| %>
        <div class="bg-base-100 p-3 font-semibold text-sm text-base-content/70">
          <%= field.name %>
          <% if field.required %>
            *
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="divide-y divide-white/20 border-b border-white/20">
      <%= form_with url: rows_path(), method: :post, html: { class: "grid gap-px divide-x divide-white/20", style: "grid-template-columns: repeat(#{ @table.fields.length }, minmax(0, 1fr));" } do |f| %>
        <input type="hidden" name="table_name" value="<%= @table.name %>">
        <% @table.fields.each do |field| %>
          <%= text_field_tag "fields[#{field.name}]",
          "",
          class: "field input input-ghost w-full rounded-none bg-white/1",
          placeholder: "new #{field.name}",
          required: field.required %>
          <%= f.submit "", class: "hidden" %>
        <% end %>
      <% end %>
      <% @table.rows.each_with_index do |row, i| %>
        <div
          class="grid gap-px bg-base-200 divide-x divide-white/20"
          style="grid-template-columns: repeat(<%= @table.fields.length %>, minmax(0, 1fr));"
        >
          <% row.items.each_with_index do |item, j| %>
            <%= form_with url: fields_path(), method: :put do |f| %>
              <input type="hidden" name="table_name" value="<%= @table.name %>">
              <input type="hidden" name="field_name" value="<%= item.field.name %>">
              <input type="hidden" name="original_row" value="<%= row.to_json %>">
              <%= f.text_field :field_value,
                           value: item.value,
                           class: "field input input-ghost w-full rounded-none",
                           required: item.field.required,
                           data: {
                             action: "input->field#check",
                             controller: "field",
                             field_original_value: item.value,
                             field_index_value: "#{i}#{j}",
                             field_field_outlet: ".field",
                           } %>
              <%= f.submit "", class: "hidden" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
