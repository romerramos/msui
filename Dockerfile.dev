FROM mcr.microsoft.com/devcontainers/ruby

# Install MySQL official APT repository and client
RUN apt-get update && apt-get install -y --no-install-recommends \
  wget \
  lsb-release \
  gnupg \
  && wget -q https://dev.mysql.com/get/mysql-apt-config_0.8.39-1_all.deb \
  && DEBIAN_FRONTEND=noninteractive dpkg -i mysql-apt-config_0.8.39-1_all.deb \
  && apt-get update \
  && apt-get install -y --no-install-recommends \
  libmysqlclient-dev \
  mysql-community-client \
  tmux \
  curl \
  ca-certificates \
  tar \
  ripgrep \
  && rm -rf /var/lib/apt/lists/* mysql-apt-config_0.8.39-1_all.deb

# Install latest stable Neovim from official GitHub releases
ARG NVIM_VERSION=v0.12.1
RUN curl -fsSL "https://github.com/neovim/neovim/releases/download/${NVIM_VERSION}/nvim-linux-x86_64.tar.gz" \
  | tar -xz -C /usr/local --strip-components=1

# Install opencode
RUN curl -fsSL https://opencode.ai/install | bash

# Rename the vscode user (UID 1000) to devuser
RUN usermod -l devuser vscode && \
  groupmod -n devuser vscode && \
  usermod -d /home/devuser -m devuser && \
  echo "devuser ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/devuser && \
  chmod 0440 /etc/sudoers.d/devuser

USER devuser
